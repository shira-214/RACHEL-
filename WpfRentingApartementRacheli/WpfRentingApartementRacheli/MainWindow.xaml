<Window x:Class="WpfRentingApartementRacheli.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:WpfRentingApartementRacheli"
        mc:Ignorable="d"
        Title="MainWindow" Height="450" Width="800">



    <Grid Background="#FDFBF7">
        <Grid.RowDefinitions>
            <RowDefinition Height="100"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <Border Grid.Row="0" Background="White" CornerRadius="0,0,15,15">
            <Border.Effect>
                <DropShadowEffect BlurRadius="10" ShadowDepth="2" Opacity="0.1"/>
            </Border.Effect>

            <Grid Margin="30,0">
                <TextBlock Text="המשכיר" Foreground="#0078D7" FontSize="28" FontWeight="Bold" 
                       HorizontalAlignment="Right" VerticalAlignment="Center" Cursor="Hand" MouseDown="TextBlock_MouseDown" />

                <StackPanel Orientation="Horizontal" HorizontalAlignment="Left" VerticalAlignment="Center">
                    <!--<Button Content="כניסת מנהל" x:Name="wmanager" Click="worder_Click" Width="100"/>-->

                    <!--<Button Content="בית" x:Name="mmain" Click="wmain_Click" Width="80"/>-->
                    <Button Content="חיפוש דירה" x:Name="wsearch" Click="wsearch_Click" Width="100"/>
                    <Button Content="הוספת דירה" x:Name="aadd" Click="wadd_Click" Width="100"/>
                    <Button Content="אזור אישי" x:Name="worder" Click="worder_Click" Width="100"/>

                </StackPanel>
            </Grid>
        </Border>

        <Frame Grid.Row="1" x:Name="MyFrame" NavigationUIVisibility="Hidden" Margin="10"/>
    </Grid>

