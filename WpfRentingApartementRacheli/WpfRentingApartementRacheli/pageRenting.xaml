<Page x:Class="WpfRentingApartementRacheli.pageRenting"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      xmlns:local="clr-namespace:WpfRentingApartementRacheli"
      mc:Ignorable="d" 
      d:DesignHeight="450" d:DesignWidth="800"
      Title="הזמנת דירה"
      FlowDirection="RightToLeft">

    <Grid Background="#FDFBF7">
        <StackPanel Margin="30" MaxWidth="450" HorizontalAlignment="Center">
            <TextBlock Text="הזמנת דירה" FontSize="24" FontWeight="Bold" Margin="0,0,0,20"/>
            <TextBlock x:Name="tbApartmentInfo" FontSize="16" Margin="0,0,0,15"/>

            <TextBlock Text="מספר מיטות להזמנה" Margin="0,0,0,5"/>
            <TextBox x:Name="txtNumBeds" TextChanged="txtNumBeds_TextChanged"/>

            <TextBlock Text="תאריך" Margin="0,10,0,5"/>
            <DatePicker x:Name="dp"/>

            <TextBlock Text="סכום לתשלום" Margin="0,10,0,5"/>
            <TextBlock x:Name="tbSumToPay" FontSize="18" FontWeight="Bold"/>

            <TextBlock Text="פרטי אשראי" FontSize="18" FontWeight="Bold" Margin="0,20,0,10"/>

            <TextBlock Text="מספר כרטיס" Margin="0,0,0,5"/>
            <TextBox x:Name="txtCard" MaxLength="16">
                <TextBox.Text>
                    <Binding UpdateSourceTrigger="PropertyChanged">
                        <Binding.ValidationRules>
                            <local:IsCreditCard/>
                        </Binding.ValidationRules>
                    </Binding>
                </TextBox.Text>
            </TextBox>

            <TextBlock Text="CVV" Margin="0,10,0,5"/>
            <TextBox x:Name="txtCvv" MaxLength="3">
                <TextBox.Text>
                    <Binding UpdateSourceTrigger="PropertyChanged">
                        <Binding.ValidationRules>
                            <local:IsCvv/>
                        </Binding.ValidationRules>
                    </Binding>
                </TextBox.Text>
            </TextBox>

            <TextBlock Text="תוקף (MM/YY)" Margin="0,10,0,5"/>
            <TextBox x:Name="txtExpiry" MaxLength="5"/>

            <Button Content="סיום הזמנה" Margin="0,25,0,0" Padding="10" Click="Button_Click"/>
        </StackPanel>
    </Grid>
</Page>
