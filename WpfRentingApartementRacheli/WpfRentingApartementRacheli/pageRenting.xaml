<Page x:Class="WpfRentingApartementRacheli.pageRenting"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      xmlns:local="clr-namespace:WpfRentingApartementRacheli"
      mc:Ignorable="d" 
      d:DesignHeight="450" d:DesignWidth="800"
      Title="pageRenting">

    <Grid>
        <StackPanel>
            <TextBlock>התחברות: </TextBlock>
            <!--<TextBlock>הכנס תעודת זהות: </TextBlock>
            <TextBox x:Name="txtId"></TextBox>-->
            <!--<Button Click="Button_Click_1" >התחברות</Button>-->
            <TextBlock>הכנס מספר מיטות</TextBlock>
            <TextBox x:Name="txtNumBeds" TextChanged="txtNumBeds_TextChanged"></TextBox>
            <TextBlock>תאריך:</TextBlock>
            <DatePicker Name="dp"></DatePicker>
            <TextBlock>סכום לתשלום: </TextBlock>
            <TextBlock x:Name="tbSumToPay"></TextBlock>
            <Button Click="Button_Click">סיום הזמנה</Button>
        </StackPanel>
        
    </Grid>
</Page>
