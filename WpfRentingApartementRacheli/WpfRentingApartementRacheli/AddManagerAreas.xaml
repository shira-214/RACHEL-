<Page x:Class="WpfRentingApartementRacheli.AddManagerAreas"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      xmlns:local="clr-namespace:WpfRentingApartementRacheli"
      mc:Ignorable="d" 
      d:DesignHeight="450" d:DesignWidth="800"
      Title="AddManagerAreas">

    <Grid>
        <StackPanel>
            <TextBlock Text="להוספת אזור" VerticalAlignment="Center" HorizontalAlignment="Center" Width="200"/>

            <TextBlock Text="אזור"/>
            <TextBox x:Name="txtNameArea" >
                <TextBox.Text>

                    <Binding Path="NameArea">
                        <Binding.ValidationRules>
                            <local:isHebrewOrEnglish/>
                        </Binding.ValidationRules>
                    </Binding>
                </TextBox.Text>
            </TextBox>
            <Button Cursor="Hand" x:Name="btnEnd" Content="סיימתי" Click="btnEnd_Click"/>

        </StackPanel>
    </Grid>
</Page>
