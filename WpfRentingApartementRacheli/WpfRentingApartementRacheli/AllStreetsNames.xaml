<Page x:Class="WpfRentingApartementRacheli.AllStreetsNames"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      xmlns:local="clr-namespace:WpfRentingApartementRacheli"
      mc:Ignorable="d" 
      d:DesignHeight="450" d:DesignWidth="800"
      Title="AllStreetsNames">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="0.3*"/>
            <RowDefinition/>
        </Grid.RowDefinitions>
        <StackPanel Orientation="Horizontal">
            <Button Content="הוספת רחוב" Margin="3,0" Click="Button_Click"/>
            <Button Content="עדכון רחוב" Margin="3,0" Click="Button_Click_1"/>
            <Button Content="מחיקת רחוב" Margin="3,0" Click="Button_Click_1"/>

        </StackPanel>
        <DataGrid x:Name="dg1" Grid.Row="1"/>
        <ListView x:Name="lvImages" Background="Beige" Grid.Row="1" >
            <ListView.View>
                <GridView>
                    <GridViewColumn Header=" קוד רחוב" DisplayMemberBinding="{Binding IdStreet}"/>
                    <GridViewColumn Header=" שם רחוב " DisplayMemberBinding="{Binding StreetName}"/>


                </GridView>
            </ListView.View>
        </ListView>



    </Grid>
</Page>
