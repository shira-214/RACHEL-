<UserControl x:Class="WpfRentingApartementRacheli.USC.OSCApartment"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:WpfRentingApartementRacheli.USC"
             mc:Ignorable="d" 
             Height="400" Width="300" Margin="5" BorderBrush="Black" Background="White" BorderThickness="2" >


    <Grid>
        <StackPanel FlowDirection="RightToLeft" Grid.ColumnSpan="2" >
            <TextBlock Margin="3" FontSize="20" x:Name="tbIdCities" Text="עיר"></TextBlock>
            <TextBlock Margin="3" FontSize="20" x:Name="tbIdStreet" Text="רחוב"></TextBlock>
            <TextBlock Margin="3" FontSize="20" x:Name="tbnNumberHouse" Text="מספר בית"></TextBlock>
            <TextBlock Margin="3" FontSize="20" x:Name="tbFloor" Text="קומה"></TextBlock>
            <TextBlock Margin="3" FontSize="20" x:Name="tbMinimumPrice" Text="מחיר"></TextBlock>
            <TextBlock Margin="3" FontSize="20" x:Name="tbNumberBeds" Text="תוספת למיטה"></TextBlock>

            




            <Border  Width="150" Height="200" BorderThickness="5" BorderBrush="Pink">
                <Image x:Name="image" Width="150" Height="200"></Image>
            </Border>
            <StackPanel x:Name="stpAddBasket">
                <StackPanel Margin="0,7,0,0" Orientation="Horizontal" HorizontalAlignment="Center">
                    <Button x:Name="plus" Content="+" Width="50" Click="plus_Click" ></Button>
                    <Border Margin="3,0,3,0" BorderThickness="2" BorderBrush="#FF7BFF00" Width="50">
                        <TextBlock Text="0" x:Name="tbAmountOrder" HorizontalAlignment="Center" FontSize="15"></TextBlock>
                    </Border>
                    <Button x:Name="minus" Content="-" Width="50" Click="minus_Click" ></Button>
                </StackPanel>
                <Button x:Name="addBasketButton" Margin="0,5,0,0" BorderThickness="2" Width="150" Content="להוספה לסל" Click="addBasketButton_Click" ></Button>

            </StackPanel>
        </StackPanel>
    </Grid>
</UserControl>
