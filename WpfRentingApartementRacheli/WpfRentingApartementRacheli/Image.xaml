<Page x:Class="WpfRentingApartementRacheli.POrders"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      mc:Ignorable="d" 
      d:DesignHeight="450" d:DesignWidth="800"
      Title="הוספת תמונה"
      FlowDirection="RightToLeft">

    <Grid Background="#FDFBF7">
        <ScrollViewer VerticalScrollBarVisibility="Auto">
        <StackPanel Margin="30" MaxWidth="450" HorizontalAlignment="Center">
            <TextBlock Text="הוספת תמונה לדירה" FontSize="24" FontWeight="Bold" Margin="0,0,0,10"/>
            <TextBlock x:Name="tbApartment" FontSize="16" Margin="0,0,0,20"/>

            <Border Height="200" Width="280" BorderBrush="#DDD" BorderThickness="1" Margin="0,0,0,15">
                <Image x:Name="imagePreview" Stretch="Uniform"/>
            </Border>

            <Button Content="בחר תמונה" Height="40" Margin="0,0,0,10" Click="btnSelect_Click"/>
            <Button Content="שמור תמונה" Height="40" Margin="0,0,0,10" Click="btnSave_Click"/>
            <Button Content="הוסף תמונה נוספת" Height="40" Margin="0,0,0,10" Click="btnAddAnother_Click"/>

            <TextBlock Text="תמונות קיימות" FontSize="16" FontWeight="Bold" Margin="0,10,0,5"/>
            <ListView x:Name="lvExistingImages" Height="120" Margin="0,0,0,15">
                <ListView.View>
                    <GridView>
                        <GridViewColumn Header="מספר" DisplayMemberBinding="{Binding NumImage}" Width="60"/>
                        <GridViewColumn Header="פעילה" DisplayMemberBinding="{Binding Stataus}" Width="60"/>
                    </GridView>
                </ListView.View>
            </ListView>

            <Button Content="חזרה ללוח בקרה" Height="40" Click="btnBack_Click"/>
        </StackPanel>
        </ScrollViewer>
    </Grid>
</Page>
