<Page x:Class="WpfRentingApartementRacheli.AddW"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      xmlns:local="clr-namespace:WpfRentingApartementRacheli"
      mc:Ignorable="d" 
      d:DesignHeight="450" d:DesignWidth="800"
      Title="הוספת דירה" Background="AliceBlue"
      FlowDirection="RightToLeft">
    <Border BorderBrush="#D3D3D3" BorderThickness="1" CornerRadius="15" Background="White" MaxWidth="550" VerticalAlignment="Center">
        <StackPanel>
            <Grid Margin="30,20">
                <ScrollViewer x:Name="RegisterPanel" Visibility="Visible" MaxHeight="600" VerticalScrollBarVisibility="Auto">
                    <StackPanel Margin="10">

                        <TextBlock Text="שם בעל הדירה*" Foreground="#3498DB" Margin="0,5" FontWeight="Bold"/>
                        <TextBox x:Name="ApartmentsNameOwner" Height="35" Margin="0,0,0,10">
                            <TextBox.Text>
                                <Binding Path="NameOwner" UpdateSourceTrigger="PropertyChanged">
                                    <Binding.ValidationRules>
                                        <local:isHebrewRule />
                                    </Binding.ValidationRules>
                                </Binding>
                            </TextBox.Text>
                        </TextBox>

                        <TextBlock Text="טלפון בעל הדירה*" Foreground="#3498DB" Margin="0,5" FontWeight="Bold"/>
                        <TextBox x:Name="txtPhoneOwner" Height="35" Margin="0,0,0,10">
                            <TextBox.Text>
                                <Binding Path="PhoneOwner" UpdateSourceTrigger="PropertyChanged">
                                    <Binding.ValidationRules>
                                        <local:IsCellPhone />
                                    </Binding.ValidationRules>
                                </Binding>
                            </TextBox.Text>
                        </TextBox>

                        <TextBlock Text="עיר*" Foreground="#3498DB" Margin="0,5" FontWeight="Bold"/>
                        <ComboBox x:Name="ApartmentCities" Height="35" Margin="0,0,0,10"
                                  DisplayMemberPath="NameCity" SelectionChanged="ApartmentCities_SelectionChanged"/>

                        <TextBlock Text="רחוב*" Foreground="#3498DB" Margin="0,5" FontWeight="Bold"/>
                        <ComboBox x:Name="ApartmentStreetsNames" Height="35" Margin="0,0,0,10" DisplayMemberPath="StreetName"
                                   SelectionChanged="ApartmentStreetsNames_SelectionChanged"/>
                        <TextBox x:Name="txtOtherStreet" Height="35" Margin="0,0,0,10" Visibility="Collapsed"
                                 ToolTip="הקלידי שם רחוב חדש"/>

                        <TextBlock Text="תוספות לדירה" Foreground="#3498DB" Margin="0,5" FontWeight="Bold"/>
                        <ComboBox x:Name="cmbExtras" Height="35" Margin="0,0,0,5" DisplayMemberPath="NameExtra"
                                  SelectionChanged="cmbExtras_SelectionChanged"/>
                        <TextBox x:Name="txtOtherExtra" Height="35" Margin="0,0,0,5" Visibility="Collapsed"
                                 ToolTip="הקלידי שם תוספת חדשה"/>
                        <Button Content="הוסף תוספת" Height="30" Margin="0,0,0,5" Click="btnAddExtra_Click"/>
                        <ListBox x:Name="lbSelectedExtras" Height="80" Margin="0,0,0,10"/>

                        <TextBlock Text="מספר בית*" Foreground="#3498DB" Margin="0,5" FontWeight="Bold"/>
                        <TextBox x:Name="txtNumberHouse" Height="35" Margin="0,0,0,10">
                            <TextBox.Text>
                                <Binding Path="NumberHouse" UpdateSourceTrigger="PropertyChanged">
                                    <Binding.ValidationRules>
                                        <local:IsNumber />
                                    </Binding.ValidationRules>
                                </Binding>
                            </TextBox.Text>
                        </TextBox>

                        <TextBlock Text="קומה*" Foreground="#3498DB" Margin="0,5" FontWeight="Bold"/>
                        <TextBox x:Name="txtFloor" Height="35" Margin="0,0,0,10">
                            <TextBox.Text>
                                <Binding Path="Floor" UpdateSourceTrigger="PropertyChanged">
                                    <Binding.ValidationRules>
                                        <local:IsNumber />
                                    </Binding.ValidationRules>
                                </Binding>
                            </TextBox.Text>
                        </TextBox>

                        <TextBlock Text="מספר חדרים*" Foreground="#3498DB" Margin="0,5" FontWeight="Bold"/>
                        <TextBox x:Name="txtNumberRooms" Height="35" Margin="0,0,0,10">
                            <TextBox.Text>
                                <Binding Path="NumberRooms" UpdateSourceTrigger="PropertyChanged">
                                    <Binding.ValidationRules>
                                        <local:IsNumber />
                                    </Binding.ValidationRules>
                                </Binding>
                            </TextBox.Text>
                        </TextBox>

                        <TextBlock Text="מספר מיטות*" Foreground="#3498DB" Margin="0,5" FontWeight="Bold"/>
                        <TextBox x:Name="txtNumberBeds" Height="35" Margin="0,0,0,10">
                            <TextBox.Text>
                                <Binding Path="NumberBeds" UpdateSourceTrigger="PropertyChanged">
                                    <Binding.ValidationRules>
                                        <local:IsNumber />
                                    </Binding.ValidationRules>
                                </Binding>
                            </TextBox.Text>
                        </TextBox>

                        <TextBlock Text="מחיר מינימום*" Foreground="#3498DB" Margin="0,5" FontWeight="Bold"/>
                        <TextBox x:Name="txtMinimumPrice" Height="35" Margin="0,0,0,10">
                            <TextBox.Text>
                                <Binding Path="MinimumPrice" UpdateSourceTrigger="PropertyChanged">
                                    <Binding.ValidationRules>
                                        <local:IsNumber />
                                    </Binding.ValidationRules>
                                </Binding>
                            </TextBox.Text>
                        </TextBox>

                        <TextBlock Text="תוספת למיטה*" Foreground="#3498DB" Margin="0,5" FontWeight="Bold"/>
                        <TextBox x:Name="txtExtraForBed" Height="35" Margin="0,0,0,10">
                            <TextBox.Text>
                                <Binding Path="ExtraForBed" UpdateSourceTrigger="PropertyChanged">
                                    <Binding.ValidationRules>
                                        <local:IsNumber />
                                    </Binding.ValidationRules>
                                </Binding>
                            </TextBox.Text>
                        </TextBox>

                        <TextBlock Text="הערות*" Foreground="#3498DB" Margin="0,5" FontWeight="Bold"/>
                        <TextBox x:Name="txtnote" Height="60" TextWrapping="Wrap" Margin="0,0,0,10">
                            <TextBox.Text>
                                <Binding Path="note" UpdateSourceTrigger="PropertyChanged"/>
                            </TextBox.Text>
                        </TextBox>

                        <CheckBox x:Name="chkStatus" Content="דירה פעילה (מוצגת בחיפוש)"
                                  Visibility="Collapsed" Margin="0,0,0,20"/>

                        <Button x:Name="btnSave" Content="הוסף דירה" Height="45" Click="Register_Click"
                                Foreground="White" Background="#3498DB" FontWeight="Bold" Cursor="Hand"/>
                        <Button Content="חזרה" Height="40" Margin="0,10,0,0" Click="btnBack_Click"/>
                    </StackPanel>
                </ScrollViewer>
            </Grid>
        </StackPanel>
    </Border>
</Page>
