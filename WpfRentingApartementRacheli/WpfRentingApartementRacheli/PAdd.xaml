<Page x:Class="WpfRentingApartementRacheli.AddW"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      xmlns:local="clr-namespace:WpfRentingApartementRacheli"
      mc:Ignorable="d" 
      d:DesignHeight="450" d:DesignWidth="800"
      Title="AddW" Background="AliceBlue">
    <Border BorderBrush="#D3D3D3" BorderThickness="1" CornerRadius="15" Background="White" MaxWidth="550" VerticalAlignment="Center">
        <StackPanel>

            <Grid Margin="30,20">
                <StackPanel x:Name="LoginPanel" Visibility="Collapsed">
                    <TextBlock Text="שם משתמש או אימייל" Foreground="#3498DB" Margin="0,5"/>
                    <TextBox Height="35" Margin="0,0,0,15"/>
                    <TextBlock Text="סיסמה" Foreground="#3498DB" Margin="0,5"/>
                    <PasswordBox Height="35" Margin="0,0,0,15"/>
                    <Button Content="כניסה" Height="45" Click="Button_Click"/>
                </StackPanel>
                <ScrollViewer x:Name="RegisterPanel" Visibility="Visible" MaxHeight="600" VerticalScrollBarVisibility="Auto">
                    <StackPanel Margin="10">

                        <TextBlock Text="שם בעל הדירה*" Foreground="#3498DB" Margin="0,5" FontWeight="Bold"/>
                        <TextBox x:Name="ApartmentsNameOwner" Height="35" Margin="0,0,0,10">
                            <TextBox.Text>
                                <Binding Path="userNameOwner" UpdateSourceTrigger="PropertyChanged">
                                    <Binding.ValidationRules>
                                        <local:isHebrewRule />
                                    </Binding.ValidationRules>
                                </Binding>
                            </TextBox.Text>
                        </TextBox>

                        <TextBlock Text="טלפון בעל הדירה*" Foreground="#3498DB" Margin="0,5" FontWeight="Bold"/>
                        <TextBox x:Name="txtPhoneOwner" Height="35" Margin="0,0,0,10">
                            <TextBox.Text>
                                <Binding Path="phone" UpdateSourceTrigger="PropertyChanged">
                                    <Binding.ValidationRules>
                                        <local:IsCellPhone />
                                    </Binding.ValidationRules>
                                </Binding>
                            </TextBox.Text>
                        </TextBox>

                        <TextBlock Text="עיר*" Foreground="#3498DB" Margin="0,5" FontWeight="Bold"/>
                        <ComboBox x:Name="ApartmentCities" Height="35" Margin="0,0,0,10" DisplayMemberPath="CityName"/>

                        <TextBlock Text="רחוב*" Foreground="#3498DB" Margin="0,5" FontWeight="Bold"/>
                        <ComboBox x:Name="ApartmentStreetsNames" Height="35" Margin="0,0,0,10" DisplayMemberPath="StreetName"/>

                        <TextBlock Text="מספר בית*" Foreground="#3498DB" Margin="0,5" FontWeight="Bold"/>
                        <TextBox x:Name="txtNumberHouse" Height="35" Margin="0,0,0,10">
                            <TextBox.Text>
                                <Binding Path="houseNum" UpdateSourceTrigger="PropertyChanged">
                                    <Binding.ValidationRules>
                                        <local:IsNumber />
                                    </Binding.ValidationRules>
                                </Binding>
                            </TextBox.Text>
                        </TextBox>

                        <TextBlock Text="קומה*" Foreground="#3498DB" Margin="0,5" FontWeight="Bold"/>
                        <TextBox x:Name="txtFloor" Height="35" Margin="0,0,0,10">
                            <TextBox.Text>
                                <Binding Path="floor" UpdateSourceTrigger="PropertyChanged">
                                    <Binding.ValidationRules>
                                        <local:IsNumber />
                                    </Binding.ValidationRules>
                                </Binding>
                            </TextBox.Text>
                        </TextBox>

                        <TextBlock Text="מספר חדרים*" Foreground="#3498DB" Margin="0,5" FontWeight="Bold"/>
                        <TextBox x:Name="txtNumberRooms" Height="35" Margin="0,0,0,10">
                            <TextBox.Text>
                                <Binding Path="numRooms" UpdateSourceTrigger="PropertyChanged">
                                    <Binding.ValidationRules>
                                        <local:IsNumber />
                                    </Binding.ValidationRules>
                                </Binding>
                            </TextBox.Text>
                        </TextBox>

                        <TextBlock Text="מספר מיטות*" Foreground="#3498DB" Margin="0,5" FontWeight="Bold"/>
                        <TextBox x:Name="txtNumberBeds" Height="35" Margin="0,0,0,10">
                            <TextBox.Text>
                                <Binding Path="numBeds" UpdateSourceTrigger="PropertyChanged">
                                    <Binding.ValidationRules>
                                        <local:IsNumber />
                                    </Binding.ValidationRules>
                                </Binding>
                            </TextBox.Text>
                        </TextBox>

                        <TextBlock Text="מחיר מינימום*" Foreground="#3498DB" Margin="0,5" FontWeight="Bold"/>
                        <TextBox x:Name="txtMinimumPrice" Height="35" Margin="0,0,0,10">
                            <TextBox.Text>
                                <Binding Path="minPrice" UpdateSourceTrigger="PropertyChanged">
                                    <Binding.ValidationRules>
                                        <local:IsNumber />
                                    </Binding.ValidationRules>
                                </Binding>
                            </TextBox.Text>
                        </TextBox>

                        <TextBlock Text="תוספת למיטה*" Foreground="#3498DB" Margin="0,5" FontWeight="Bold"/>
                        <TextBox x:Name="txtExtraForBed" Height="35" Margin="0,0,0,10">
                            <TextBox.Text>
                                <Binding Path="extraBed" UpdateSourceTrigger="PropertyChanged">
                                    <Binding.ValidationRules>
                                        <local:IsNumber />
                                    </Binding.ValidationRules>
                                </Binding>
                            </TextBox.Text>
                        </TextBox>

                        <TextBlock Text="הערות*" Foreground="#3498DB" Margin="0,5" FontWeight="Bold"/>
                        <TextBox x:Name="txtnote" Height="60" TextWrapping="Wrap" Margin="0,0,0,20">
                            <TextBox.Text>
                                <Binding Path="note" UpdateSourceTrigger="PropertyChanged"/>
                            </TextBox.Text>
                        </TextBox>

                        <Button Content="מעבר להוספת תמונה" Height="45" Click="Register_Click"  Foreground="White" FontWeight="Bold" Cursor="Hand"/>
                    </StackPanel>
                </ScrollViewer>
            </Grid>
        </StackPanel>
    </Border>

</Page>
