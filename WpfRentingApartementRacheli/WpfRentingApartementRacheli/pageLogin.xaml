<Page x:Class="WpfRentingApartementRacheli.pageLogin"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      xmlns:local="clr-namespace:WpfRentingApartementRacheli"
      mc:Ignorable="d" 
      d:DesignHeight="450" d:DesignWidth="800"
      Title="כניסת שוכר"
      FlowDirection="RightToLeft">

    <Grid Background="#FDFBF7">
        <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center" Width="400">
            <TextBlock Text="ברוכים הבאים" FontSize="28" FontWeight="Bold" HorizontalAlignment="Center" Margin="0,0,0,25"/>
            <TextBlock Text="הקש תעודת זהות" FontSize="14" Margin="0,0,0,5"/>
            <TextBox x:Name="txtId" MaxLength="9">
                <TextBox.Text>
                    <Binding Path="C_IDHirer" UpdateSourceTrigger="PropertyChanged">
                        <Binding.ValidationRules>
                            <local:IsId/>
                        </Binding.ValidationRules>
                    </Binding>
                </TextBox.Text>
            </TextBox>
            <TextBlock Text="לדוגמה: 123456782" FontSize="12" Foreground="Gray" Margin="0,0,0,10"/>
            <Button Click="Button_Click" Margin="0,10,0,0">התחבר</Button>
            <Button Click="Button_Click_1">לרישום לחץ כאן</Button>
            <Button Content="חזרה" Margin="0,15,0,0" Click="btnBack_Click"/>
        </StackPanel>
    </Grid>
</Page>
