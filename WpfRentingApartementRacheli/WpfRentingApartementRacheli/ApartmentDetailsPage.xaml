<Page x:Class="WpfRentingApartementRacheli.ApartmentDetailsPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      mc:Ignorable="d" 
      d:DesignHeight="450" d:DesignWidth="800"
      Title="פרטי דירה"
      FlowDirection="RightToLeft">

    <Grid Background="#FDFBF7">
        <ScrollViewer VerticalScrollBarVisibility="Auto">
            <StackPanel Margin="30" MaxWidth="600" HorizontalAlignment="Center">

                <TextBlock Text="פרטי דירה" FontSize="24" FontWeight="Bold" Margin="0,0,0,15"/>
                <TextBlock x:Name="tbTitle" FontSize="20" FontWeight="Bold" Margin="0,0,0,20"/>

                <Border Height="250" BorderBrush="#DDD" BorderThickness="1" Margin="0,0,0,10">
                    <Image x:Name="imgMain" Stretch="Uniform"/>
                </Border>

                <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,0,0,20">
                    <Button x:Name="btnPrev" Content="הקודם" Width="80" Margin="5,0" Click="btnPrev_Click"/>
                    <TextBlock x:Name="tbImageCounter" VerticalAlignment="Center" Margin="10,0" FontWeight="Bold"/>
                    <Button x:Name="btnNext" Content="הבא" Width="80" Margin="5,0" Click="btnNext_Click"/>
                </StackPanel>

                <TextBlock Text="פרטים" FontSize="18" FontWeight="Bold" Margin="0,0,0,10"/>
                <StackPanel Orientation="Horizontal" Margin="0,0,0,5">
                    <TextBlock Text="קומה: "/>
                    <TextBlock x:Name="tbFloor"/>
                </StackPanel>
                <StackPanel Orientation="Horizontal" Margin="0,0,0,5">
                    <TextBlock Text="חדרים: "/>
                    <TextBlock x:Name="tbRooms"/>
                </StackPanel>
                <StackPanel Orientation="Horizontal" Margin="0,0,0,5">
                    <TextBlock Text="מיטות: "/>
                    <TextBlock x:Name="tbBeds"/>
                </StackPanel>
                <StackPanel Orientation="Horizontal" Margin="0,0,0,5">
                    <TextBlock Text="מחיר התחלתי: "/>
                    <TextBlock x:Name="tbMinPrice"/>
                    <TextBlock Text=" ש''ח"/>
                </StackPanel>
                <StackPanel Orientation="Horizontal" Margin="0,0,0,5">
                    <TextBlock Text="תוספת למיטה: "/>
                    <TextBlock x:Name="tbExtraBed"/>
                    <TextBlock Text=" ש''ח"/>
                </StackPanel>

                <TextBlock Text="הערות" FontSize="16" FontWeight="Bold" Margin="0,15,0,5"/>
                <TextBlock x:Name="tbNote" TextWrapping="Wrap" Margin="0,0,0,15"/>

                <TextBlock Text="מה יש בדירה?" FontSize="16" FontWeight="Bold" Margin="0,0,0,5"/>
                <ListBox x:Name="lbExtras" Height="100" Margin="0,0,0,20"/>

                <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                    <Button Content="הזמן עכשיו" Width="120" Height="40" Margin="5" Click="btnBook_Click"/>
                    <Button Content="חזרה לחיפוש" Width="120" Height="40" Margin="5" Click="btnBack_Click"/>
                </StackPanel>

            </StackPanel>
        </ScrollViewer>
    </Grid>
</Page>
