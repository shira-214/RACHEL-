<Page x:Class="WpfRentingApartementRacheli.AllAraesCitiesStreet"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      xmlns:local="clr-namespace:WpfRentingApartementRacheli"
      mc:Ignorable="d" 
      d:DesignHeight="450" d:DesignWidth="800"
      Title="AllAraesCitiesStreet">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="0.3*"/>
            <RowDefinition/>
        </Grid.RowDefinitions>
        <StackPanel Orientation="Horizontal">
            <Button Content="אזור חדש בעיר" Margin="3,0" Click="Button_Click"/>
            <Button Content="עדכון אזור בעיר" Margin="3,0" Click="Button_Click_1"/>
            <Button Content="מחיקת אזור בעיר" Margin="3,0" Click="Button_Click_2"/>

        </StackPanel>
        <DataGrid x:Name="dg1" Grid.Row="1"/>
        <ListView x:Name="lvAraesCitiesStreet" Background="Beige" Grid.Row="1" >
            <ListView.View>
                <GridView>
                    <GridViewColumn Header="קוד רחוב" DisplayMemberBinding="{Binding DTOStreetsNames.StreetName}"/>
                    <GridViewColumn Header="קוד עיר " DisplayMemberBinding="{Binding DTOCities.NameCity}"/>
                    <GridViewColumn Header="קוד אזור" DisplayMemberBinding="{Binding DTOAreas.NameArea}"/>

                </GridView>
            </ListView.View>
        </ListView>



    </Grid>
</Page>
<!--public DTOStreetsNames IdStreetDTo { get; set; }
        public DTOCities IdCities { get; set; }
        public DTOAreas IdArea { get; set; }-->


