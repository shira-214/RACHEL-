<Page x:Class="WpfRentingApartementRacheli.AddManagerAraesCitiesStreet"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      xmlns:local="clr-namespace:WpfRentingApartementRacheli"
      mc:Ignorable="d" 
      d:DesignHeight="450" d:DesignWidth="800"
      Title="קישור אזור-עיר-רחוב">

    <Grid>
        <StackPanel>
            <TextBlock Text="עיר "/>
            <ComboBox Foreground="Pink" Background="Aqua" x:Name="ApartmentCities" SelectedValue="{Binding Cities}"  DisplayMemberPath="NameCity" />

            <TextBlock Text="רחוב"/>

            <ComboBox Foreground="Pink" Background="Aqua" x:Name="ApartmentStreetsNames" SelectedValue="{Binding StreetsNames}"  DisplayMemberPath="StreetName" ></ComboBox>


            <TextBlock Text="אזורי רחובות בערים"/>
            <ComboBox Foreground="Pink" Background="Aqua" x:Name="ApartmentArea" SelectedValue="{Binding Areas}"  DisplayMemberPath="NameArea" ></ComboBox>

            <!--<TextBox x:Name="txtNameArea" >
                <TextBox.Text>-->

                    <!--<Binding Path="StreetName">
                        <Binding.ValidationRules>
                            <local:isHebrewOrEnglish/>
                        </Binding.ValidationRules>
                    </Binding>
                </TextBox.Text>
            </TextBox>-->
            <Button Cursor="Hand" x:Name="btnEnd" Content="סיימתי" Click="btnEnd_Click"/>

        </StackPanel>
</Grid>
</Page>
