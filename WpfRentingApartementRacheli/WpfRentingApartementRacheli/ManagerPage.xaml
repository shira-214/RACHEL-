<Page x:Class="WpfRentingApartementRacheli.ManagerPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      xmlns:local="clr-namespace:WpfRentingApartementRacheli"
      mc:Ignorable="d" 
      d:DesignHeight="450" d:DesignWidth="800"
      Title="ניהול מערכת">

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="6*" />
            <ColumnDefinition Width="2*" />
        </Grid.ColumnDefinitions>
        <Frame Grid.Row="1" Background="AliceBlue" Name="ManagerFramre"/>
        <StackPanel Grid.Column ="1" >
            <Button Content="דירות" Click="Button_Click" />
            <Button Content="אזורי רחוב בערים" Click="Button_Click_1"/>
            <Button Content="אזורים" Click="Button_Click_2"/>
            <Button Content="ערים" Click="Button_Click_3"/>
            <Button Content="תוספות בדירה" Click="Button_Click_4"/>
            <Button Content="רשימת משכירים" Click="Button_Click_6"/>
            <Button Content="הזמנות" Click="Button_Click_8"/>
            <Button Content="רחובות" Click="Button_Click_9"/>
        </StackPanel>
    </Grid>
</Page>
