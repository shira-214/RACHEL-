<Page x:Class="WpfRentingApartementRacheli.LogInApartement"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      xmlns:local="clr-namespace:WpfRentingApartementRacheli"
      mc:Ignorable="d" 
      d:DesignHeight="450" d:DesignWidth="800"
      Title="LogInApartement">

    <Grid>
        <StackPanel>
            <TextBlock Text="כניסה" HorizontalAlignment="Center" FontSize="35" FontWeight="Bold" Margin="6"></TextBlock>
            <TextBlock FontSize="20" HorizontalAlignment="Center" Text="שם משתמש:"></TextBlock>
            <TextBox x:Name="txtHirerName"   FontSize="20" HorizontalAlignment="Center" Width="200"></TextBox>
            <TextBlock FontSize="20" HorizontalAlignment="Center" Text="תעודת זהות " ></TextBlock>
            <PasswordBox x:Name="txtPassword"  FontSize="20" HorizontalAlignment="Center" Width="200"  ></PasswordBox>
            <Button Click="Button_Click" FontSize="13"  Margin="5" Height="30" Width="200" HorizontalAlignment="Center" Content="להתחברות" Background="#FFF3CBA5" ></Button>
            <Button FontSize="13" Margin="5" Height="30" Width="200" HorizontalAlignment="Center" Content="משתמש חדש? לרישום לחץ כאן👈" Background="#FFF3CBA5" Click="Button_Click_1"></Button>
            <Button FontSize="13" Margin="5" Height="30" Width="200"  HorizontalAlignment="Center" Content="כניסת מנהל" Background="#FFF3CBA5" Click="Button_Click_2" ></Button>
        </StackPanel>

    </Grid>
</Page>
