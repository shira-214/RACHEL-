<Page x:Class="WpfRentingApartementRacheli.AllOwners"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      mc:Ignorable="d" 
      d:DesignHeight="450" d:DesignWidth="800"
      Title="רשימת משכירים" FlowDirection="RightToLeft">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <TextBlock Text="משכירים רשומים במערכת (לפי דירות)" FontWeight="Bold" Margin="5"/>

        <ListView x:Name="lvOwners" Background="White" Grid.Row="1">
            <ListView.View>
                <GridView>
                    <GridViewColumn Header="שם משכיר" DisplayMemberBinding="{Binding NameOwner}" Width="150"/>
                    <GridViewColumn Header="טלפון" DisplayMemberBinding="{Binding PhoneOwner}" Width="120"/>
                    <GridViewColumn Header="מספר דירות" DisplayMemberBinding="{Binding ApartmentCount}" Width="90"/>
                </GridView>
            </ListView.View>
        </ListView>
    </Grid>
</Page>
