<Page x:Class="WpfRentingApartementRacheli.SearchW"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      mc:Ignorable="d" 
      d:DesignHeight="600" d:DesignWidth="800"
      Title="חיפוש דירה"
      FlowDirection="RightToLeft">

    <Grid Margin="0,0,0,10" Background="#FDFBF7">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="Auto"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <Border Background="#007ACC" CornerRadius="20" Width="280"
                HorizontalAlignment="Left" VerticalAlignment="Stretch" Margin="20" Padding="15">
            <ScrollViewer VerticalScrollBarVisibility="Auto">
            <StackPanel>
                <TextBlock Text="חפש דירה" FontSize="22" FontWeight="Bold" Foreground="White"
                           HorizontalAlignment="Center" Margin="0,0,0,15"/>

                <TextBlock Text="אזור" Foreground="White" HorizontalAlignment="Center" Margin="0,5,0,0"/>
                <ComboBox x:Name="ApartmentAreas" Height="35" Margin="0,5"
                          DisplayMemberPath="NameArea" SelectionChanged="Filter_Changed"/>

                <TextBlock Text="עיר" Foreground="White" HorizontalAlignment="Center" Margin="0,10,0,0"/>
                <ComboBox x:Name="ApartmentCities" Height="35" Margin="0,5"
                          DisplayMemberPath="NameCity" SelectionChanged="Filter_Changed"/>

                <TextBlock Text="רחוב" Foreground="White" HorizontalAlignment="Center" Margin="0,10,0,0"/>
                <ComboBox x:Name="ApartmentStreetsNames" Height="35" Margin="0,5"
                          DisplayMemberPath="StreetName" SelectionChanged="Filter_Changed"/>

                <TextBlock Text="תאריך" Foreground="White" HorizontalAlignment="Center" Margin="0,10,0,0"/>
                <DatePicker x:Name="dp" Margin="0,5" SelectedDateChanged="DatePicker_SelectedDateChanged"/>

                <TextBlock Text="מחיר ללילה (עד)" Foreground="White" HorizontalAlignment="Center" Margin="0,10,0,0"/>
                <Slider x:Name="slPrice" Minimum="100" Maximum="5000" Value="5000" Margin="0,5"
                        ValueChanged="Filter_Changed" TickFrequency="100" IsSnapToTickEnabled="True"/>
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                    <TextBlock Text="עד " Foreground="White" FontSize="12"/>
                    <TextBlock Text="{Binding ElementName=slPrice, Path=Value}" Foreground="White" FontSize="12" FontWeight="Bold"/>
                    <TextBlock Text=" ש''ח" Foreground="White" FontSize="12"/>
                </StackPanel>

                <TextBlock Text="מספר מיטות (מינימום)" Foreground="White" HorizontalAlignment="Center" Margin="0,10,0,0"/>
                <Slider x:Name="slBeds" Minimum="1" Maximum="30" Value="1" Margin="0,5" ValueChanged="Filter_Changed"/>
                <TextBlock Text="{Binding ElementName=slBeds, Path=Value, StringFormat={}{0:F0}}"
                           Foreground="White" HorizontalAlignment="Center" FontSize="12"/>

                <TextBlock Text="מה יש בדירה?" Foreground="White" HorizontalAlignment="Center"
                           Margin="0,15,0,5" FontWeight="Bold"/>
                <ComboBox x:Name="ApartmentExtras" Height="35" Margin="0,5"
                          DisplayMemberPath="NameExtra" SelectionChanged="Filter_Changed"/>

                <Button Content="מצא לי דירה" Background="White" Margin="0,15,0,0"
                        FontWeight="Bold" Click="Button_Click"/>
            </StackPanel>
            </ScrollViewer>
        </Border>

        <ScrollViewer Grid.Column="1" VerticalScrollBarVisibility="Auto">
            <WrapPanel x:Name="wrp"/>
        </ScrollViewer>
    </Grid>
</Page>
