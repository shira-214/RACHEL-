<Page x:Class="WpfRentingApartementRacheli.AddManagerImages"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      xmlns:local="clr-namespace:WpfRentingApartementRacheli"
      mc:Ignorable="d" 
      d:DesignHeight="450" d:DesignWidth="800"
      Title="AddManagerImages">

    <Grid>
        <Grid>
            <StackPanel>
                <TextBlock Text="תמונה"/>
                <TextBox x:Name="txtExtras" >
                    <TextBox.Text>

                        <Binding Path="userExtras">
                            <Binding.ValidationRules>
                                <local:isHebrewRule/>
                            </Binding.ValidationRules>
                        </Binding>
                    </TextBox.Text>
                </TextBox>
                <Button Cursor="Hand" x:Name="btnEnd" Content="סיימתי" Click="btnEnd_Click"/>

            </StackPanel>


        </Grid>


</Grid>
</Page>
