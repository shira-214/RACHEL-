<Page x:Class="WpfRentingApartementRacheli.AllImages"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      xmlns:local="clr-namespace:WpfRentingApartementRacheli"
      mc:Ignorable="d" 
      d:DesignHeight="450" d:DesignWidth="800"
      Title="ניהול תמונות" FlowDirection="RightToLeft">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="0.3*"/>
            <RowDefinition/>
        </Grid.RowDefinitions>
        <StackPanel Orientation="Horizontal">
            <Button Content="תמונה חדשה" Margin="3,0" Click="Button_Click" />
            <Button Content="עדכון תמונה" Margin="3,0" Click="Button_Click_1"/>
            <Button Content="מחיקת תמונה" Click="Button_Click_2"/>
        </StackPanel>
        <ListView x:Name="lvImages" Background="White" Grid.Row="1" >
            <ListView.View>
                <GridView>
                    <GridViewColumn Header=" מספר תמונה" DisplayMemberBinding="{Binding NumImage}"/>
                    <GridViewColumn Header=" מיקום תמונה " DisplayMemberBinding="{Binding Image1}"/>
                    <GridViewColumn Header=" סטטוס" DisplayMemberBinding="{Binding Stataus}"/>
                    <GridViewColumn Header="דירה (טלפון בעל)" DisplayMemberBinding="{Binding IdApartement.PhoneOwner}"/>


                </GridView>
            </ListView.View>
        </ListView>


    </Grid>
</Page>
